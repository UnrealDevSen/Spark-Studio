rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    match /users/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow list: if false; // Users shouldn't be listing all users
      
      // Strict keys check for create
      allow create: if isOwner(userId) && isValidId(userId)
                    && request.resource.data.keys().hasAll(['uid', 'email', 'name', 'photoURL', 'tier', 'createdAt', 'updatedAt'])
                    && request.resource.data.keys().size() == 7
                    && request.resource.data.uid == userId
                    && request.resource.data.tier in ['free', 'premium']
                    && request.resource.data.name is string && request.resource.data.name.size() > 0 && request.resource.data.name.size() <= 100
                    && request.resource.data.email is string && request.resource.data.email.size() > 0 && request.resource.data.email.size() <= 150
                    && request.resource.data.photoURL is string && request.resource.data.photoURL.size() <= 500;

      allow update: if isOwner(userId) && isValidId(userId)
                    && request.resource.data.uid == resource.data.uid
                    && request.resource.data.createdAt == resource.data.createdAt
                    && request.resource.data.tier in ['free', 'premium']
                    && request.resource.data.name is string && request.resource.data.name.size() > 0 && request.resource.data.name.size() <= 100
                    && request.resource.data.email is string && request.resource.data.email.size() > 0 && request.resource.data.email.size() <= 150
                    && request.resource.data.photoURL is string && request.resource.data.photoURL.size() <= 500;
                    
      allow delete: if false;

      match /streams/{streamId} {
        allow read: if isOwner(userId) && isValidId(userId) && isValidId(streamId);
        
        allow create: if isOwner(userId) && isValidId(userId) && isValidId(streamId)
                      && request.resource.data.keys().hasAll(['userId', 'title', 'platform', 'peakViewers', 'views', 'avgRetention', 'chatEngaged', 'createdAt', 'updatedAt'])
                      && request.resource.data.keys().size() == 9
                      && request.resource.data.userId == userId
                      && request.resource.data.title is string && request.resource.data.title.size() > 0 && request.resource.data.title.size() <= 200
                      && request.resource.data.platform in ['Twitch', 'YouTube']
                      && request.resource.data.peakViewers is number
                      && request.resource.data.views is number
                      && request.resource.data.avgRetention is number
                      && request.resource.data.chatEngaged is number;

        allow update: if isOwner(userId) && isValidId(userId) && isValidId(streamId)
                      && request.resource.data.userId == resource.data.userId
                      && request.resource.data.createdAt == resource.data.createdAt
                      && request.resource.data.title is string && request.resource.data.title.size() > 0 && request.resource.data.title.size() <= 200
                      && request.resource.data.platform in ['Twitch', 'YouTube']
                      && request.resource.data.peakViewers is number
                      && request.resource.data.views is number
                      && request.resource.data.avgRetention is number
                      && request.resource.data.chatEngaged is number;
                      
        allow delete: if isOwner(userId) && isValidId(userId) && isValidId(streamId);
      }

      match /integrations/{docId} {
        allow read: if isOwner(userId) && isValidId(userId) && docId == 'status';
        allow create, update: if isOwner(userId) && isValidId(userId) && docId == 'status'
                              && request.resource.data.keys().hasAll(['twitchConnected', 'youtubeConnected', 'instagramConnected', 'updatedAt'])
                              && request.resource.data.keys().size() == 4
                              && request.resource.data.twitchConnected is bool
                              && request.resource.data.youtubeConnected is bool
                              && request.resource.data.instagramConnected is bool;
        allow delete: if false;
      }
    }
  }
}
